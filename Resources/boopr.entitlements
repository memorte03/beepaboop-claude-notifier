<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Boopr drives Ghostty via AppleScript (TmuxFocuser); under the hardened
         runtime, sending Apple Events to other apps requires this entitlement. -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
</dict>
</plist>
